{
  "name": "@repo/ui",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "lint": "biome lint ./src/",
    "lint:fix": "biome lint --write ./src/",
    "fmt": "biome format --write ./src/",
    "check": "biome check ./src/",
    "check:fix": "biome check --fix ./src/"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^18.2.14",
    "tsup": "^8.0.1",
    "typescript": "5.5.4"
  },
  "dependencies": {
    "@biomejs/biome": "^1.9.4",
    "react": "^18.2.0",
    "react-native": "0.74.5"
  },
  "biome": {
    "configPath": "../../biome.json"
  }
}
